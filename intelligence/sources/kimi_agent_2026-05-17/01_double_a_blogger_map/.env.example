# ADHD×AI 情报自动流系统 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# ==================== X/Twitter API ====================
# 获取方式: https://developer.twitter.com/en/portal/dashboard
# 需要: Elevated access (免费)
X_BEARER_TOKEN=your_x_bearer_token_here

# ==================== Reddit API ====================
# 获取方式: https://www.reddit.com/prefs/apps
# 创建应用 → 获取 client_id 和 client_secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ADHDIntelligenceBot/1.0 (by /u/your_username)

# ==================== Anthropic Claude API ====================
# 获取方式: https://console.anthropic.com/
# 新用户有免费额度
ANTHROPIC_API_KEY=your_claude_api_key

# ==================== OpenAI API (可选) ====================
# 获取方式: https://platform.openai.com/
# Claude为主，OpenAI备用
OPENAI_API_KEY=your_openai_api_key_optional

# ==================== 数据存储 ====================
DATA_DIR=./adhd_ai_data
