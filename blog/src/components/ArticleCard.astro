---
interface Props {
  title: string;
  subtitle?: string;
  category: string;
  categoryId: string;
  date: string;
  readingTime?: number;
  tags?: string[];
  slug: string;
  rank?: number;
  score?: number;
}

const { title, subtitle, category, categoryId, date, readingTime, tags, slug, rank, score } = Astro.props;

const categoryColors: Record<string, string> = {
  "ai-tools": "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
  "focus": "bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300",
  "time-mgmt": "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300",
  "emotion": "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300",
  "learning": "bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-300",
  "career": "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300",
  "entrepreneurship": "bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300",
  "parenting": "bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-300",
  "science": "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300",
  "lifestyle": "bg-violet-100 text-violet-700 dark:bg-violet-900/30 dark:text-violet-300",
  "community": "bg-lime-100 text-lime-700 dark:bg-lime-900/30 dark:text-lime-300",
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const colorClass = categoryColors[categoryId] || "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300";
---

<a href={`${base}/articles/${slug}`} class="article-card group block">
  <div class="flex items-start justify-between gap-3">
    <span class={`category-badge ${colorClass} shrink-0`}>
      {category}
    </span>
    {rank && rank <= 20 && (
      <span class="flex items-center gap-1 text-xs font-semibold text-amber-500">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        Top {rank}
      </span>
    )}
  </div>

  <h3 class="mt-4 text-lg font-bold leading-snug transition-colors group-hover:text-brand-500 line-clamp-2">
    {title}
  </h3>

  {subtitle && (
    <p class="mt-2 text-sm text-[var(--color-text-secondary)] line-clamp-2">
      {subtitle}
    </p>
  )}

  <div class="mt-4 flex flex-wrap gap-1.5">
    {tags?.slice(0, 3).map((tag) => (
      <span class="tag-pill">{tag}</span>
    ))}
  </div>

  <div class="mt-4 flex items-center justify-between text-xs text-[var(--color-text-secondary)]">
    <span>{date}</span>
    {readingTime && <span>{readingTime} 分钟阅读</span>}
  </div>

  {score && (
    <div class="mt-3 h-1.5 w-full overflow-hidden rounded-full bg-gray-200 dark:bg-gray-700">
      <div
        class="h-full rounded-full bg-gradient-to-r from-brand-400 to-purple-500 transition-all duration-500"
        style={`width: ${Math.min(score / 10 * 100, 100)}%`}
      />
    </div>
  )}
</a>
