---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ArticleCard from "../components/ArticleCard.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles");

// Sort by score descending
const sortedArticles = allArticles.sort(
  (a, b) => (b.data.score || 0) - (a.data.score || 0)
);

// Build category info
const categoryMap = new Map<string, { id: string; name: string; icon: string; count: number }>();
const categoryIcons: Record<string, string> = {
  "ai-tools": "🛠️", "focus": "🎯", "time-mgmt": "⏰", "emotion": "💚",
  "learning": "📚", "career": "💼", "entrepreneurship": "🚀",
  "parenting": "👨‍👩‍👧‍👦", "science": "🔬", "lifestyle": "🌟", "community": "🌍",
};

for (const article of sortedArticles) {
  const catId = article.data.categoryId;
  const existing = categoryMap.get(catId);
  if (existing) {
    existing.count++;
  } else {
    categoryMap.set(catId, {
      id: catId,
      name: article.data.category,
      icon: categoryIcons[catId] || "📄",
      count: 1,
    });
  }
}

const categories = Array.from(categoryMap.values());
---

<BaseLayout title="ADHD × AI - 400篇精选文章">
  <Hero totalArticles={sortedArticles.length} totalCategories={categories.length} />

  <section id="articles" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Search -->
    <div class="mb-8">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="搜索文章标题、标签..."
          class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] py-3 pl-12 pr-4 text-sm transition-colors focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-400/20"
        />
      </div>
    </div>

    <!-- Category Filter -->
    <div class="mb-8">
      <CategoryFilter categories={categories} />
    </div>

    <!-- Results count -->
    <div class="mb-6 text-sm text-[var(--color-text-secondary)]">
      共 <span id="visible-count">{sortedArticles.length}</span> 篇文章
    </div>

    <!-- Articles Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="articles-grid">
      {sortedArticles.map((article) => (
        <div data-article-category={article.data.categoryId} data-article-title={article.data.title} data-article-tags={article.data.tags?.join(",")}>
          <ArticleCard
            title={article.data.title}
            subtitle={article.data.subtitle}
            category={article.data.category}
            categoryId={article.data.categoryId}
            date={article.data.date}
            readingTime={article.data.readingTime}
            tags={article.data.tags}
            slug={article.id}
            rank={article.data.rank}
            score={article.data.score}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Search functionality
  const searchInput = document.getElementById("search-input");
  searchInput?.addEventListener("input", (e) => {
    const query = e.target.value.toLowerCase().trim();
    const cards = document.querySelectorAll("[data-article-title]");
    let visibleCount = 0;

    cards.forEach((card) => {
      const title = (card.dataset.articleTitle || "").toLowerCase();
      const tags = (card.dataset.articleTags || "").toLowerCase();
      const matches = !query || title.includes(query) || tags.includes(query);

      if (matches && card.style.display !== "none") {
        card.style.removeProperty("display");
        visibleCount++;
      } else if (!matches) {
        card.style.display = "none";
      } else {
        visibleCount++;
      }
    });

    const countEl = document.getElementById("visible-count");
    if (countEl) countEl.textContent = visibleCount.toString();
  });
</script>
